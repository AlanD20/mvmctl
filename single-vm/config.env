# Load centralized asset configuration
if [ -f "../assets/config.env" ]; then
  source "../assets/config.env"
else
  echo "ERROR: ../assets/config.env not found. Run ../assets/download-assets.sh first."
  exit 1
fi

# -----------------------------------------------------------------------------
# VM Identity
# -----------------------------------------------------------------------------

VM_NAME='fc-vm-01'
OUTPUT_DIR="${OUTPUT_DIR:-env}"

# -----------------------------------------------------------------------------
# VM Resources
# -----------------------------------------------------------------------------

VM_VCPU=2
VM_MEM_MIB=2048
DISK_SIZE="${IMAGE_SIZE:-2G}"

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------

TAP_DEV="fc-tap0"
GUEST_IP="10.10.0.2"
HOST_IP="10.10.0.1"
MAC="02:FC:00:00:00:01"
MASK="255.255.255.252"

# -----------------------------------------------------------------------------
# Firecracker API
# -----------------------------------------------------------------------------

# Enable API socket ("true") or run with --no-api ("false")
ENABLE_SOCKET="${ENABLE_SOCKET:-false}"

# Enable PCI device support — required by some distributions
ENABLE_PCI="${ENABLE_PCI:-false}"

# LSM modules to enable in the guest kernel
BOOT_ARG_LSM_FLAGS="landlock,lockdown,yama,integrity,selinux,bpf"

# -----------------------------------------------------------------------------
# Asset Paths (resolved from IMAGE_SOURCE set in assets/config.env)
# -----------------------------------------------------------------------------

KERNEL_PATH="../assets/${KERNEL_PATH}"

case "$IMAGE_SOURCE" in
  "ubuntu-cloud")
    ROOTFS_PATH="../assets/images/${UBUNTU_VERSION}.ext4"
    ;;
  "arch-linux")
    ROOTFS_PATH="../assets/images/arch.btrfs"
    ;;
  "debian")
    DEBIAN_VERSION="${DEBIAN_VERSION:-bookworm}"
    ROOTFS_PATH="../assets/images/debian-${DEBIAN_VERSION}.ext4"
    ;;
  "custom")
    if [ -z "$CUSTOM_ROOTFS" ]; then
      echo "ERROR: IMAGE_SOURCE='custom' but CUSTOM_ROOTFS is not set in assets/config.env"
      exit 1
    fi
    ROOTFS_PATH="$CUSTOM_ROOTFS"
    if [ -n "$CUSTOM_KERNEL" ]; then
      KERNEL_PATH="$CUSTOM_KERNEL"
    else
      KERNEL_PATH="../assets/kernels/vmlinux"
      echo "WARNING: CUSTOM_KERNEL not set, falling back to generic kernel"
    fi
    ;;
  *)
    # Default: Firecracker CI — pick up whatever ubuntu image is available
    ROOTFS_FILE=$(ls ../assets/images/ubuntu-*.ext4 2>/dev/null | head -1)
    IMAGE_VERSION=$([ -n "$ROOTFS_FILE" ] && basename "$ROOTFS_FILE" .ext4 | sed 's/ubuntu-//' || echo "24.04")
    ROOTFS_PATH="../assets/images/ubuntu-${IMAGE_VERSION}.ext4"
    ;;
esac

export IMAGE_SOURCE ROOTFS_PATH KERNEL_PATH
