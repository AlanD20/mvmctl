#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_build:
	test -f dist/mvm || { echo "dist/mvm not found — build it first with: go build -o dist/mvm ./cmd/mvm"; exit 1; }
	mkdir -p debian/mvmctl/usr/bin
	cp dist/mvm debian/mvmctl/usr/bin/
	chmod 755 debian/mvmctl/usr/bin/mvm

override_dh_auto_install:
	# Install man page
	mkdir -p debian/mvmctl/usr/share/man/man1
	cp docs/mvm.1 debian/mvmctl/usr/share/man/man1/
	gzip -9 debian/mvmctl/usr/share/man/man1/mvm.1

override_dh_auto_clean:
	# No clean needed
