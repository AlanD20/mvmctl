#!/bin/bash
# =============================================================================
# MULTI-VM CONFIGURATION
# =============================================================================

# =============================================================================
# LOAD CENTRALIZED CONFIGURATION
# =============================================================================
if [ -f "../assets/config.env" ]; then
	source "../assets/config.env"
else
	echo "ERROR: ../assets/config.env not found. Run ../assets/download-assets.sh first."
	exit 1
fi

# =============================================================================
# VM DEFAULTS
# =============================================================================
OUTPUT_DIR="${OUTPUT_DIR:-env}"
ENABLE_SOCKET="${ENABLE_SOCKET:-false}"
DISK_SIZE="${IMAGE_SIZE:-2G}"

# =============================================================================
# NETWORK CONFIGURATION (Bridge Mode)
# =============================================================================
BRIDGE_NAME="fc-br0"
BRIDGE_IP="10.20.0.1/24"
GUEST_IP_START="10.20.0.2"
GUEST_IP_END="10.20.0.254"
TAP_PREFIX="fc"

# =============================================================================
# VM PATHS (determined by IMAGE_SOURCE from assets/config.env)
# =============================================================================
# Paths are auto-configured based on IMAGE_SOURCE:
# - "ubuntu-cloud": Uses Ubuntu cloud-images (noble, jammy, etc.)
# - "firecracker-ci": Uses Firecracker CI minimal images
# - "arch-linux": Uses Arch Linux cloud image
# - "debian": Uses Debian cloud image
# - "almalinux": Uses AlmaLinux cloud image
# - "fedora": Uses Fedora cloud image
# - "custom": Uses CUSTOM_ROOTFS and CUSTOM_KERNEL from assets/config.env

case "$IMAGE_SOURCE" in
  "ubuntu-cloud")
    KERNEL_PATH="../assets/kernels/${UBUNTU_VERSION}-vmlinux"
    ROOTFS_PATH="../assets/images/${UBUNTU_VERSION}.ext4"
    ;;
  "arch-linux")
    KERNEL_PATH="../assets/kernels/arch-vmlinux"
    ROOTFS_PATH="../assets/images/arch.btrfs"
    ;;
  "debian")
    # Use detected debian version or default to bookworm
    DEBIAN_VERSION="${DEBIAN_VERSION:-bookworm}"
    KERNEL_PATH="../assets/kernels/debian-${DEBIAN_VERSION}-vmlinux"
    ROOTFS_PATH="../assets/images/debian-${DEBIAN_VERSION}.ext4"
    ;;
  "almalinux")
    KERNEL_PATH="../assets/kernels/almalinux-9-vmlinux"
    ROOTFS_PATH="../assets/images/almalinux-9.ext4"
    ;;
  "fedora")
    FEDORA_VERSION="${FEDORA_VERSION:-39}"
    KERNEL_PATH="../assets/kernels/fedora-${FEDORA_VERSION}-vmlinux"
    ROOTFS_PATH="../assets/images/fedora-${FEDORA_VERSION}.ext4"
    ;;
  "custom")
    # Use custom paths from assets/config.env
    if [ -n "$CUSTOM_ROOTFS" ]; then
      ROOTFS_PATH="$CUSTOM_ROOTFS"
    else
      echo "ERROR: IMAGE_SOURCE='custom' but CUSTOM_ROOTFS is not set in assets/config.env"
      exit 1
    fi
    if [ -n "$CUSTOM_KERNEL" ]; then
      KERNEL_PATH="$CUSTOM_KERNEL"
    else
      # Fallback to generic kernel
      KERNEL_PATH="../assets/kernels/vmlinux"
      echo "WARNING: IMAGE_SOURCE='custom' but CUSTOM_KERNEL not set, using generic kernel"
    fi
    ;;
  *)
    # Default: Firecracker CI
    # Get version from available rootfs
    ROOTFS_FILE=$(ls ../assets/images/ubuntu-*.ext4 2>/dev/null | head -1)
    if [ -n "$ROOTFS_FILE" ]; then
      IMAGE_VERSION=$(basename "$ROOTFS_FILE" .ext4 | sed 's/ubuntu-//')
    else
      IMAGE_VERSION="24.04"
    fi
    KERNEL_PATH="../assets/kernels/vmlinux"
    ROOTFS_PATH="../assets/images/ubuntu-${IMAGE_VERSION}.ext4"
    ;;
esac

# Export for use in scripts
export IMAGE_SOURCE
export ROOTFS_PATH
export KERNEL_PATH

