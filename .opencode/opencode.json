{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "architect": {
      "mode": "primary",
      "prompt": "{file:./agent/architect.md}",
      "model": "opencode-go/kimi-k2.7-code"
    },
    "engineer": {
      "mode": "all",
      "prompt": "{file:./agent/engineer.md}",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "qa": {
      "mode": "all",
      "prompt": "{file:./agent/qa-engineer.md}",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "build": {
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "general": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "explore": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash"
    }
  }
}
