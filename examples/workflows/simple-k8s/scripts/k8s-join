#!/bin/bash
set -e

CTRL_VM="${1:-controller-1}"
FILENAME="${2:-join-worker}"

for _ in $(seq 1 30); do
  if [ -S /var/run/containerd/containerd.sock ]; then break; fi
  sleep 2
done

if [ -f /etc/kubernetes/kubelet.conf ]; then
  echo "already joined"
  exit 0
fi

echo "fetching join command from $CTRL_VM:/srv/k8s/$FILENAME..."
JOBS=$(timeout 60 mvm-agent remote "$CTRL_VM" -- cat "/srv/k8s/$FILENAME")

if [ -z "$JOBS" ]; then
  echo "failed to get join command"
  exit 1
fi

echo "running: $JOBS"
bash -c "$JOBS"
