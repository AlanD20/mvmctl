#!/bin/bash
set -e

hostnamectl set-hostname builder 2>/dev/null || true

apt-get update
apt-get install -y vim netcat-openbsd curl wget htop tmux dnsutils iproute2 iputils-ping traceroute ethtool tcpdump lsof strace tree git jq keepalived
apt-get install -y ca-certificates curl gpg

curl -fsSL https://pkgs.k8s.io/core:/stable:/v1.36/deb/Release.key | gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg
echo "deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.36/deb/ /" > /etc/apt/sources.list.d/kubernetes.list
apt-get update
apt-get install -y containerd kubelet kubeadm kubectl
apt-mark hold kubelet kubeadm kubectl containerd

mkdir -p /etc/containerd
containerd config default > /etc/containerd/config.toml
sed -i 's/SystemdCgroup = false/SystemdCgroup = true/' /etc/containerd/config.toml
systemctl restart containerd 2>/dev/null || true
systemctl enable kubelet 2>/dev/null || true

kubeadm config images pull 2>/dev/null || true

ctr image pull quay.io/cilium/cilium:v1.19.3 2>/dev/null || true
ctr image pull quay.io/cilium/cilium-envoy:v1.19.3 2>/dev/null || true
ctr image pull quay.io/cilium/operator-generic:v1.19.3 2>/dev/null || true
ctr image pull quay.io/cilium/hubble-relay:v1.19.3 2>/dev/null || true
ctr image pull quay.io/cilium/hubble-ui:v1.19.3 2>/dev/null || true
ctr image pull quay.io/cilium/hubble-ui-backend:v1.19.3 2>/dev/null || true
ctr image pull ghcr.io/kube-vip/kube-vip:v0.9.1 2>/dev/null || true

cat > /etc/modules-load.d/k8s.conf <<'EOF'
overlay
br_netfilter
EOF
modprobe overlay || true
modprobe br_netfilter || true

cat > /etc/sysctl.d/k8s.conf <<'EOF'
net.bridge.bridge-nf-call-iptables  = 1
net.bridge.bridge-nf-call-ip6tables = 1
net.ipv4.ip_forward                 = 1
EOF
sysctl --system || true
