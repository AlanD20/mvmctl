# Single VM generated environment
single-vm/env/

# Multi VM generated environments and VMs
multi-vm/env/
multi-vm/vms/

# Generated temporary files
**/*.iso
**/*.img
**/*.img
**/*.ext4
**/*.log
**/*.metrics
**/*.pid
**/*.socket

# Editor and OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
