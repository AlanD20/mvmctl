# Centralized configuration for shared assets
# NOTE: Most values are now dynamically detected by download-assets.sh
# This file provides defaults and documentation

# =============================================================================
# IMAGE SOURCE SELECTION
# =============================================================================
# Choose one: "firecracker-ci" or "ubuntu-cloud"
# - "firecracker-ci": Downloads from Firecracker CI S3 bucket (minimal images)
# - "ubuntu-cloud": Downloads from Ubuntu official cloud-images (full Ubuntu with cloud-init)
IMAGE_SOURCE="ubuntu-cloud"

# =============================================================================
# UBUNTU-CLOUD OPTIONS (used when IMAGE_SOURCE="ubuntu-cloud")
# =============================================================================
# Ubuntu version (e.g., "noble", "jammy", "focal")
UBUNTU_VERSION="noble"

# Image size (default: 2G for cloud-init support)
IMAGE_SIZE="2G"

# =============================================================================
# FIRECRACKER-CI OPTIONS (used when IMAGE_SOURCE="firecracker-ci")
# =============================================================================
# Rootfs pattern (version is dynamically detected from CI)
ROOTFS_PATTERN="images/ubuntu-*.ext4"

# OS configuration (informational, actual version detected from CI)
IMAGE_OS="ubuntu"
IMAGE_ARCH="x86_64"

# =============================================================================
# KERNEL CONFIGURATION
# =============================================================================
# Kernel path (fixed location, dynamically downloaded)
KERNEL_PATH="kernels/vmlinux"

# =============================================================================
# FIRECRACKER BINARIES
# =============================================================================
FIRECRACKER_PATH="bin/firecracker"
JAILER_PATH="bin/jailer"
