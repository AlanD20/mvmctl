# Centralized configuration for shared assets
# NOTE: Most values are now dynamically detected by download-assets.sh
# This file provides defaults and documentation

# Kernel path (fixed location, dynamically downloaded)
KERNEL_PATH="kernels/vmlinux"

# Rootfs pattern (version is dynamically detected from CI)
ROOTFS_PATTERN="images/ubuntu-*.ext4"

# SSH key pattern (matches rootfs version)
SSH_KEY_PATTERN="images/ubuntu-*.id_rsa"

# OS configuration (informational, actual version detected from CI)
IMAGE_OS="ubuntu"
IMAGE_ARCH="x86_64"

# Firecracker binary location
FIRECRACKER_PATH="bin/firecracker"
JAILER_PATH="bin/jailer"
